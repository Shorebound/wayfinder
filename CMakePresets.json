{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 1
    },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "description": "Shared options inherited by all presets — not used directly",
            "cacheVariables": {
                "CPM_SOURCE_CACHE": "${sourceDir}/thirdparty",
                "WAYFINDER_BUILD_SANDBOX": "ON",
                "WAYFINDER_BUILD_TOOLS": "ON",
                "WAYFINDER_BUILD_TESTS": "ON",
                "WAYFINDER_BUILD_EDITOR": "OFF",
                "WAYFINDER_BUILD_RUNTIME": "OFF",
                "WAYFINDER_BUILD_SAMPLES": "OFF",
                "WAYFINDER_ENABLE_PROFILING": "ON"
            }
        },
        {
            "name": "dev",
            "displayName": "Development (Ninja + MSVC)",
            "description": "Daily-driver preset. Ninja + MSVC for fast builds and native compile_commands.json. Requires cl.exe in PATH (use VS Developer Shell).",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            }
        },
        {
            "name": "dev-all",
            "displayName": "Development (Everything)",
            "description": "Builds all targets including editor, runtime, and samples",
            "inherits": "dev",
            "cacheVariables": {
                "WAYFINDER_BUILD_EDITOR": "ON",
                "WAYFINDER_BUILD_RUNTIME": "ON",
                "WAYFINDER_BUILD_SAMPLES": "ON"
            }
        },
        {
            "name": "dev-vs",
            "displayName": "Development (Visual Studio IDE)",
            "description": "VS 2022 generator for opening in Visual Studio. Use 'dev' for VS Code.",
            "inherits": "_base",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc"
        },
        {
            "name": "dev-clang",
            "displayName": "Development (Clang on Windows)",
            "description": "Clang catches warnings MSVC misses. Useful for cross-compiler validation and static analysis.",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/clang",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "WAYFINDER_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "dev-clang-tidy",
            "displayName": "Development (Clang + clang-tidy)",
            "description": "Clang build with clang-tidy static analysis on every compile",
            "inherits": "dev-clang",
            "cacheVariables": {
                "WAYFINDER_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "shipping",
            "displayName": "Shipping",
            "description": "Sandbox only, no dev tooling or profiling",
            "inherits": "dev",
            "binaryDir": "${sourceDir}/build/shipping",
            "cacheVariables": {
                "WAYFINDER_BUILD_TOOLS": "OFF",
                "WAYFINDER_BUILD_TESTS": "OFF",
                "WAYFINDER_ENABLE_PROFILING": "OFF"
            }
        },
        {
            "name": "ci-linux",
            "displayName": "CI (Linux / Clang)",
            "description": "Linux CI — Ninja + Clang with libc++",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++",
                "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -lc++abi",
                "WAYFINDER_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "ci-windows",
            "displayName": "CI (Windows / MSVC)",
            "description": "Windows CI — Ninja + MSVC with warnings-as-errors",
            "inherits": "dev",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "WAYFINDER_WARNINGS_AS_ERRORS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "configurePreset": "dev",
            "configuration": "Debug"
        },
        {
            "name": "development",
            "displayName": "Development",
            "configurePreset": "dev",
            "configuration": "Development"
        },
        {
            "name": "shipping",
            "displayName": "Shipping",
            "configurePreset": "shipping",
            "configuration": "Shipping"
        },
        {
            "name": "clang-debug",
            "displayName": "Clang (Debug)",
            "configurePreset": "dev-clang",
            "configuration": "Debug"
        },
        {
            "name": "clang-tidy-debug",
            "displayName": "Clang + Tidy (Debug)",
            "configurePreset": "dev-clang-tidy",
            "configuration": "Debug"
        },
        {
            "name": "ci-linux-debug",
            "displayName": "CI Linux (Debug)",
            "configurePreset": "ci-linux",
            "configuration": "Debug"
        },
        {
            "name": "ci-windows-debug",
            "displayName": "CI Windows (Debug)",
            "configurePreset": "ci-windows",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "test",
            "displayName": "Run Tests (Debug)",
            "configurePreset": "dev",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        },
        {
            "name": "clang-test",
            "displayName": "Run Tests (Clang)",
            "configurePreset": "dev-clang",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        },
        {
            "name": "ci-linux-test",
            "displayName": "Run Tests (CI Linux)",
            "configurePreset": "ci-linux",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        },
        {
            "name": "ci-windows-test",
            "displayName": "Run Tests (CI Windows)",
            "configurePreset": "ci-windows",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        }
    ]
}
