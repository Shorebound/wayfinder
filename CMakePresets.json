{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 0,
        "patch": 1
    },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "description": "Shared options — not used directly",
            "cacheVariables": {
                "CPM_SOURCE_CACHE": "${sourceDir}/thirdparty",
                "CMAKE_COLOR_DIAGNOSTICS": "ON",
                "WAYFINDER_BUILD_SANDBOX": "ON",
                "WAYFINDER_BUILD_TOOLS": "ON",
                "WAYFINDER_BUILD_TESTS": "ON",
                "WAYFINDER_BUILD_EDITOR": "OFF",
                "WAYFINDER_BUILD_RUNTIME": "OFF",
                "WAYFINDER_BUILD_SAMPLES": "OFF",
                "WAYFINDER_ENABLE_PROFILING": "ON"
            }
        },
        {
            "name": "dev",
            "displayName": "Development (Ninja + Clang)",
            "description": "Ninja + Clang with LLD linker.",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_LINKER_TYPE": "LLD"
            }
        },
        {
            "name": "dev-all",
            "displayName": "Development (Everything)",
            "description": "All targets: sandbox, tools, tests, editor, runtime, and samples",
            "inherits": "dev",
            "cacheVariables": {
                "WAYFINDER_BUILD_EDITOR": "ON",
                "WAYFINDER_BUILD_RUNTIME": "ON",
                "WAYFINDER_BUILD_SAMPLES": "ON"
            }
        },
        {
            "name": "dev-tidy",
            "displayName": "Development (clang-tidy)",
            "description": "Clang build with clang-tidy static analysis on every compile",
            "inherits": "dev",
            "cacheVariables": {
                "WAYFINDER_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "dev-msvc",
            "displayName": "Development (Ninja + MSVC)",
            "description": "MSVC compiler validation.",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/msvc",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl"
            }
        },
        {
            "name": "dev-vs",
            "displayName": "Development (Visual Studio IDE)",
            "description": "VS 2022 generator for opening in Visual Studio",
            "inherits": "_base",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/vs",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "shipping",
            "displayName": "Shipping",
            "description": "Sandbox only, no dev tooling or profiling",
            "inherits": "dev",
            "binaryDir": "${sourceDir}/build/shipping",
            "cacheVariables": {
                "WAYFINDER_BUILD_TOOLS": "OFF",
                "WAYFINDER_BUILD_TESTS": "OFF",
                "WAYFINDER_ENABLE_PROFILING": "OFF"
            }
        },
        {
            "name": "ci-linux",
            "displayName": "CI (Linux)",
            "description": "Linux CI — Clang with libc++ and warnings-as-errors",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_CXX_FLAGS": "-stdlib=libc++",
                "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -lc++abi",
                "WAYFINDER_WARNINGS_AS_ERRORS": "ON",
                "WAYFINDER_ENABLE_PROFILING": "OFF"
            }
        },
        {
            "name": "ci-windows",
            "displayName": "CI (Windows)",
            "description": "Windows CI — MSVC with warnings-as-errors",
            "inherits": "_base",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl",
                "CMAKE_CXX_COMPILER": "cl",
                "WAYFINDER_WARNINGS_AS_ERRORS": "ON",
                "WAYFINDER_ENABLE_PROFILING": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "configurePreset": "dev",
            "configuration": "Debug"
        },
        {
            "name": "development",
            "displayName": "Development",
            "configurePreset": "dev",
            "configuration": "Development"
        },
        {
            "name": "shipping",
            "displayName": "Shipping",
            "configurePreset": "shipping",
            "configuration": "Shipping"
        },
        {
            "name": "msvc-debug",
            "displayName": "MSVC (Debug)",
            "configurePreset": "dev-msvc",
            "configuration": "Debug"
        },
        {
            "name": "tidy-debug",
            "displayName": "clang-tidy (Debug)",
            "configurePreset": "dev-tidy",
            "configuration": "Debug"
        },
        {
            "name": "ci-linux-debug",
            "displayName": "CI Linux (Debug)",
            "configurePreset": "ci-linux",
            "configuration": "Debug"
        },
        {
            "name": "ci-windows-debug",
            "displayName": "CI Windows (Debug)",
            "configurePreset": "ci-windows",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "test",
            "displayName": "Run Tests",
            "configurePreset": "dev",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        },
        {
            "name": "msvc-test",
            "displayName": "Run Tests (MSVC)",
            "configurePreset": "dev-msvc",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        },
        {
            "name": "ci-linux-test",
            "displayName": "Run Tests (CI Linux)",
            "configurePreset": "ci-linux",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        },
        {
            "name": "ci-windows-test",
            "displayName": "Run Tests (CI Windows)",
            "configurePreset": "ci-windows",
            "configuration": "Debug",
            "output": {
                "outputJUnitFile": "test-results.xml"
            }
        }
    ]
}
